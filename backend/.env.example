# Copy to .env and replace every "insert api key here" with your real key.
# Never commit real keys — .env is gitignored.

# --- RapidAPI (booking-com15, hotels4, hotels-com-provider, airbnb19, tripadvisor16, flights, AI Trip Planner) ---
RAPIDAPI_KEY=insert api key here
RAPIDAPI_TRIP_PLANNER_HOST=ai-trip-planner.p.rapidapi.com

# --- OpenRouter (SSE itinerary engine + supplementary trip-planner classifier) ---
OPENROUTER_API_KEY=insert api key here
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
OPENROUTER_CLASSIFIER_MODEL=anthropic/claude-haiku-4.5

# --- Other scraping / data sources ---
GOOGLE_MAPS_API_KEY=insert api key here
APIFY_API_KEY=insert api key here
DUFFEL_API_KEY=insert api key here
# Ignav (ignav.com) — flights only; free tier is 1,000 requests. Fail-soft:
# leave blank to disable. Get a key at https://ignav.com
IGNAV_API_KEY=insert api key here
# LiteAPI (Nuitée) — hotel content + live rates in one call. A sand_ key hits
# the sandbox (test data); a prod key returns real inventory. Fail-soft: leave
# blank to disable. Get a key at https://liteapi.travel
LITEAPI_API_KEY=insert api key here

# --- Server ---
PORT=4000
CACHE_TTL_SECONDS=10800
